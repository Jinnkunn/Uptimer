# Vite build-time configuration

# Optional: customize the admin URL path to reduce exposure.
#
# Example: VITE_ADMIN_PATH=/37dh3hi2
# Default: /admin
VITE_ADMIN_PATH=/admin

# Optional: enable OIDC admin login through auth.jinnkunn.com.
# The Worker must also be configured with matching UPTIMER_AUTH_* values.
#
# VITE_AUTH_ISSUER=https://auth.jinnkunn.com
# VITE_AUTH_CLIENT_ID=<registered-uptimer-spa-client-id>
# VITE_AUTH_RESOURCE=urn:jinnkunn:uptimer
# VITE_AUTH_SCOPE=openid profile email uptimer.admin
# VITE_AUTH_REDIRECT_PATH=/admin/callback
